{
  "name": "@mvp-kit/template-validator",
  "version": "0.1.2",
  "description": "Validate Handlebars variables in MVPKit template repositories",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "mvpkit-validate": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node dist/cli.js --test",
    "validate": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mvpkit",
    "template",
    "validation",
    "handlebars",
    "cli",
    "starter-kit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvp-kit/template-validator.git"
  },
  "homepage": "https://github.com/mvp-kit/template-validator#readme",
  "bugs": {
    "url": "https://github.com/mvp-kit/template-validator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
